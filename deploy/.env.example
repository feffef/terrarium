# Terrarium PoC deployment env (ADR-0011).
# Copy to /opt/terrarium/.env on the VPS and fill in. NEVER commit the real .env
# (the repo .gitignore already ignores .env).

# HTTPS clone URL, WITHOUT credentials. The supervisor injects the token at
# runtime via GIT_ASKPASS, so the PAT is never persisted in .git/config.
GIT_REPO_URL=https://github.com/feffef/terrarium.git

# Fine-grained personal access token: repository access limited to
# feffef/terrarium, permission Contents: Read-only. Rotate on expiry.
GITHUB_PAT=

# --- optional (defaults shown) ---
# Branch to track and serve.
BRANCH=main
# Seconds between update checks.
POLL_INTERVAL=120
# Internal port the Nitro node server listens on (Caddy proxies to this).
PORT=3000
