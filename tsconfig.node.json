{
  // Type-checks the node/tsx-side code that `nuxt typecheck` does NOT cover — its
  // generated tsconfig includes only the Nuxt app surface (app/, shared/, config),
  // never scripts/ or tests/. Run as the second half of `pnpm typecheck` so the
  // session-log helper and the shared isolation code are gated like the rest (ADR-0004).
  //
  // `content.config.ts` belongs here rather than in the Nuxt program: it runs in
  // the node/config context (evaluated by jiti at `nuxt prepare`/`build` time, not
  // inside the Vue/app compile), and it already imports `shared/expand.ts` — which
  // this program covers. It defines the very `Collections` keys other code depends
  // on (issue #93), and until now sat in NO tsconfig, so a type error there was
  // invisible to `pnpm typecheck`. (The tenant manifests it loads are typechecked
  // separately, via the Nuxt program's `../layers/*/tenant.config.*` include in
  // `nuxt.config.ts` — a file should be typechecked by exactly one program.)
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // scripts import sibling modules by explicit `.ts` path (tsx runtime); allow it.
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    // shared/routing.ts imports from #routing (ADR-0014 virtual module). Mirror the
    // alias that nuxt registers so `tsc -p tsconfig.node.json` can resolve it too.
    // .nuxt/routing.d.ts is generated by `nuxt prepare` (run via postinstall).
    "paths": {
      "#routing": ["./.nuxt/routing.d.ts"],
      "#catalog": ["./.nuxt/catalog.d.ts"]
    }
  },
  // Platform unit tests live in `tests/unit/`; Tenant-specific unit tests live in
  // their layer under `layers/<tenant>/tests/unit/` (tests/README.md). Both globs
  // keep every unit spec in this node program (e2e specs stay out — they need the
  // Nuxt/browser libs, not the node ones).
  "include": [
    "scripts/**/*.ts",
    "shared/**/*.ts",
    "tests/unit/**/*.ts",
    "layers/*/tests/unit/**/*.ts",
    "content.config.ts"
  ]
}
