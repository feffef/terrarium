+// Diagnostic: record a client-side dump-fetch failure so the real-world trigger
+// of the "component renders empty" bug (network blip vs. a checksum-mismatch 404
+// after a deploy vs. a 5xx) is captured the next time it happens, even if no
+// devtools are open. Appends to a small localStorage ring buffer readable as
+// JSON.parse(localStorage.__content_db_errors) and warns to the console. Fires
+// only after the retries above are exhausted — i.e. exactly when the collection
+// would otherwise be left blank until recovery. Best-effort; never throws.
+function recordDumpFetchFailure(collection, error) {
+  const entry = {
+    t: new Date().toISOString(),
+    collection: String(collection),
+    status: error?.statusCode ?? error?.response?.status ?? null,
+    message: error?.message ? String(error.message).slice(0, 200) : String(error)
+  };
+  try {
+    console.warn(
+      `[content-db] dump fetch for "${entry.collection}" failed after retries (content may render empty until the next navigation or a reload):`,
+      entry
+    );
+  } catch {
+  }
+  try {
+    const key = "__content_db_errors";
+    const log = JSON.parse(window.localStorage.getItem(key) || "[]");
+    log.push(entry);
+    while (log.length > 25) log.shift();
+    window.localStorage.setItem(key, JSON.stringify(log));
+  } catch {
+  }
+}
