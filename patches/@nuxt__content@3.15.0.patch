 export async function fetchDatabase(event, collection) {
   return fetchContent(event, collection, "sql_dump.txt", {
     responseType: "text",
+    // Ride out a transient network blip within a single query. The stock $fetch
+    // default (retry: 1 for GET) gives only two attempts; when both fail the
+    // client DB caches a rejected load promise and the collection's content is
+    // stuck empty until a full page reload. A few backed-off retries turn the
+    // common short blip into a self-healing delay instead of a permanent blank.
+    retry: 4,
+    retryDelay: 300,
     headers: {
       "content-type": "text/plain"
     }
